<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>COYL — Stop the script</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.Safari.web-extension</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).SafariExtensionHandler</string>
	</dict>
	<key>NSHumanReadableDescription</key>
	<string>Catch the tab switch before it costs the day. COYL fires at the 3-second window between trigger and action — in the browser, the surface where most procrastination happens.</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 COYL. All rights reserved.</string>
	<!--
	  App Transport Security (ATS).
	  The extension only ever fetches https://coyl.ai (see background.js).
	  We disable arbitrary loads, force TLS 1.3 + forward secrecy + Certificate
	  Transparency for the coyl.ai exception, and reserve a placeholder for
	  public-key pinning (NSPinnedDomains) — the founder fills in the SHA-256
	  SPKI hashes from the production cert before App Store submission. Pin
	  rotation lives in the deployment runbook.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>coyl.ai</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.3</string>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<true/>
				<key>NSRequiresCertificateTransparency</key>
				<true/>
			</dict>
		</dict>
		<key>NSPinnedDomains</key>
		<dict>
			<key>coyl.ai</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<!--
				  Leaf-identity pinning (least privilege).
				  Trusts only the specific coyl.ai leaf cert(s), not the
				  full CA chain — so a compromise of any trusted CA can't
				  mint a forged cert that this extension would accept.
				  Provide a backup pin so cert rotation doesn't brick the
				  extension; ship a new build with the next leaf hash
				  before the current leaf expires.
				-->
				<key>NSPinnedLeafIdentities</key>
				<array>
					<!--
					  TODO before App Store submission: replace with the
					  SHA-256 base64 SPKI hash of the live coyl.ai leaf cert.
					  Generate via:
					    openssl s_client -connect coyl.ai:443 -servername coyl.ai \
					      < /dev/null 2>/dev/null \
					      | openssl x509 -pubkey -noout \
					      | openssl pkey -pubin -outform der \
					      | openssl dgst -sha256 -binary \
					      | base64
					-->
					<dict>
						<key>SPKI-SHA256-BASE64</key>
						<string>REPLACE_WITH_PRODUCTION_LEAF_SPKI_HASH</string>
					</dict>
					<!-- Backup pin — set to the next-rotation leaf's SPKI hash. -->
					<dict>
						<key>SPKI-SHA256-BASE64</key>
						<string>REPLACE_WITH_BACKUP_LEAF_SPKI_HASH</string>
					</dict>
				</array>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
