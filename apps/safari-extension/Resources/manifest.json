{
  "manifest_version": 3,
  "name": "COYL — Stop the script",
  "short_name": "COYL",
  "version": "0.1.0",
  "description": "Catch the tab switch before it costs the day. COYL fires at the 3-second window between trigger and action — in the browser, the surface where most procrastination happens.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://coyl.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.reddit.com/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.youtube.com/*",
        "https://www.tiktok.com/*",
        "https://www.instagram.com/*",
        "https://www.facebook.com/*",
        "https://news.ycombinator.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "COYL — Stop the script"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "quick-slip": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Log a slip — one-tap confession to coyl.ai"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
