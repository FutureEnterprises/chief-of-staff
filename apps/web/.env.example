# Database — Supabase
# Pooled connection (use for app queries via Prisma + pgbouncer)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/today
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Stripe
STRIPE_SECRET_KEY="sk_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_..."
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_ANNUAL_PRICE_ID="price_..."

# Resend
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="briefing@your-domain.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron
CRON_SECRET="your-cron-secret"

# AI (Anthropic)
ANTHROPIC_API_KEY="sk-ant-..."

# Rate Limiting (Upstash Redis) — optional, degrades to no-op
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
