# =============================================================================
# COYL — apps/web environment variables
# =============================================================================
# Copy to .env.local for dev. In production, set these in Vercel
# (Project → Settings → Environment Variables) for Production + Preview.
# Anything marked NEXT_PUBLIC_ is bundled to the client — do not put secrets
# in those.

# -----------------------------------------------------------------------------
# Database — Supabase Postgres via Prisma
# -----------------------------------------------------------------------------
# Pooled connection (use for app queries via pgbouncer)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrations only)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# Auth — Clerk
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/today
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# -----------------------------------------------------------------------------
# Payments — Stripe
# -----------------------------------------------------------------------------
# Live keys for production. Test keys (sk_test_..., pk_test_...) for dev.
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
# Stripe Dashboard → Developers → Webhooks → endpoint signing secret.
# Endpoint URL: https://coyl.ai/api/webhooks/stripe
# Events to subscribe to:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs — six total, one per (tier × interval).
# Source of truth for tier mapping: src/lib/services/entitlement.service.ts
# Source of truth for displayed prices: src/app/(wedges)/pricing/pricing-view.tsx
# Mirror those when you create the Stripe Dashboard prices:
#   CORE    — $19/mo  or $179/yr  ($14.92/mo billed annually)
#   PLUS    — $29/mo  or $279/yr  ($23.25/mo billed annually)
#   PREMIUM — $49/mo  or $469/yr  ($39.08/mo billed annually)
STRIPE_CORE_MONTHLY_PRICE_ID="price_..."
STRIPE_CORE_ANNUAL_PRICE_ID="price_..."
STRIPE_PLUS_MONTHLY_PRICE_ID="price_..."
STRIPE_PLUS_ANNUAL_PRICE_ID="price_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_ANNUAL_PRICE_ID="price_..."

# Legacy — if any pre-v4 subscribers exist on these prices, the webhook will
# still map them to CORE. Safe to leave unset on fresh deploys.
# STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
# STRIPE_PRO_ANNUAL_PRICE_ID="price_..."

# Charity disbursement for the Premium-tier financial-stakes feature.
# When set, broken-commitment stake captures are automatically transferred
# (Stripe Connect Transfer) to the charity's connected account. Leave
# UNSET for v1 manual disbursement (we capture; founder emails the
# charity monthly with the total).
#
# Setup:
#   1. Onboard GiveDirectly (or alternative) as a Stripe Connected
#      Account (Standard or Express). Their finance team has to agree
#      to receive automated transfers.
#   2. Get the connected account ID (acct_xxxxx) from Stripe Connect.
#   3. Paste below. Funds flow automatically on every "broken" stake.
#
# Until the charity is onboarded, capture-only is the safe v1.
CHARITY_STRIPE_ACCOUNT_ID=""

# -----------------------------------------------------------------------------
# Email — Resend
# -----------------------------------------------------------------------------
# 1. Get the API key from Resend dashboard → API Keys
# 2. Add coyl.ai as a verified domain → Resend will give you SPF + DKIM
#    DNS records to add at your DNS provider (Cloudflare for coyl.ai)
# 3. Set RESEND_FROM_EMAIL to a verified sender on the verified domain
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="hello@coyl.ai"
# Resend audience ID for newsletter signups from /api/v1/newsletter.
# Create at Resend Dashboard → Audiences. If unset, signups are
# console-logged but not persisted (useful in dev / pre-Resend).
RESEND_AUDIENCE_ID=""

# -----------------------------------------------------------------------------
# SMS — Twilio
# -----------------------------------------------------------------------------
# Powers the /catch-me funnel-compression landing. If unset, signups are
# captured to the SmsSignup table but no SMS is sent (dev / pre-Twilio).
#
# Provision:
#   1. Sign up at twilio.com, buy a US 10DLC long-code or shortcode
#   2. Register an A2P 10DLC campaign (required for US carriers)
#   3. Either set TWILIO_FROM_NUMBER (single sender) OR
#      TWILIO_MESSAGING_SERVICE_SID (sender pool + carrier routing)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""               # +15551234567 — use OR the next
TWILIO_MESSAGING_SERVICE_SID=""     # MGxxxxxxxx — preferred at scale

# -----------------------------------------------------------------------------
# Web Push — VAPID keys
# -----------------------------------------------------------------------------
# Used by the danger-window-interrupt cron (and other interrupt crons) to
# send browser push notifications to users who subscribed via the /today
# enable banner. Closes the real-time gap for Core/Free users who don't
# have the mobile app installed yet.
#
# Generate once with: `npx web-push generate-vapid-keys`
# Then set all three in Vercel env (Production + Preview):
#   - VAPID_PUBLIC_KEY            (also exposed to the browser; must match
#                                   NEXT_PUBLIC_VAPID_PUBLIC_KEY exactly)
#   - NEXT_PUBLIC_VAPID_PUBLIC_KEY (same value as VAPID_PUBLIC_KEY)
#   - VAPID_PRIVATE_KEY           (server-only, NEVER expose)
#   - VAPID_SUBJECT               ("mailto:hello@coyl.ai" — your contact)
VAPID_PUBLIC_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@coyl.ai"

# -----------------------------------------------------------------------------
# AI — Anthropic Claude
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://coyl.ai"
# In Vercel Preview environments this should be the preview URL. In local
# dev, http://localhost:3000.

# -----------------------------------------------------------------------------
# Cron auth — internal-only secret for /api/cron/* endpoints
# -----------------------------------------------------------------------------
# Vercel injects `vercel-cron` in CRON_HEADER_NAME for first-party crons,
# but external pingers and local runs hit the secret check.
CRON_SECRET="generate-with-openssl-rand-base64-32"

# -----------------------------------------------------------------------------
# Rate limiting — Upstash Redis (optional, no-op fallback)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
