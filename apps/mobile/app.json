{
  "expo": {
    "name": "COYL",
    "slug": "coyl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "coyl",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0a0a0a",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "ai.coyl.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:coyl.ai",
        "applinks:www.coyl.ai"
      ],
      "privacyManifests": {
        "usesDataCollection": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSHealthShareUsageDescription": "COYL reads your steps, sleep, and heart rate to detect stress patterns and danger windows — so it can interrupt your autopilot before a slip.",
        "NSHealthUpdateUsageDescription": "COYL does not write to HealthKit.",
        "NSUserNotificationsUsageDescription": "COYL fires surgical interrupts at the exact moments you usually lose. Notifications are how it catches you before the fold.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "ai.coyl.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ff6600"
      },
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "coyl.ai"
            },
            {
              "scheme": "https",
              "host": "www.coyl.ai"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ff6600"
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "COYL reads your steps, sleep, and heart rate to detect stress patterns and danger windows — so it can interrupt your autopilot before a slip.",
          "NSHealthUpdateUsageDescription": "COYL does not write to HealthKit.",
          "background": {
            "HKQuantityTypeIdentifierStepCount": 2,
            "HKCategoryTypeIdentifierSleepAnalysis": 2,
            "HKQuantityTypeIdentifierHeartRate": 2,
            "HKQuantityTypeIdentifierRestingHeartRate": 2,
            "HKQuantityTypeIdentifierHeartRateVariabilitySDNN": 2
          }
        }
      ],
      [
        "react-native-health-connect",
        {
          "package": "ai.coyl.app"
        }
      ],
      "./plugins/with-coyl-live-activity",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d132e0f4-de67-4781-bffa-2ac2d32ab5b4"
      },
      "router": {
        "origin": false
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/d132e0f4-de67-4781-bffa-2ac2d32ab5b4"
    },
    "owner": "coyl-ai"
  }
}
