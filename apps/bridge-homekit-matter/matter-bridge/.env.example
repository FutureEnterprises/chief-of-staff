# COYL Matter Bridge — environment.
# Copy to .env.local and fill in. Never commit secrets.

# Bearer token issued to the user from coyl.ai/settings/eap > "Issue bridge token".
# Tied to a single userId on the server; rotated from the same UI.
COYL_USER_TOKEN=

# API base. Override for local dev (preview deploy, ngrok, etc).
COYL_API_BASE=https://coyl.ai

# Matter fabric state on disk. The Docker image overrides this to /data/fabric.
COYL_MATTER_STORAGE_PATH=./.matter-fabric

# Poll interval in ms. Lower = lower action latency, higher EAP server load.
# 3000ms gives ~3.5s p95 action latency end-to-end which is fine for the
# wind-down scenario; tighten to 1000 once we move to websocket.
EAP_POLL_INTERVAL_MS=3000

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
