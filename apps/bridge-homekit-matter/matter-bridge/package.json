    "dotenv": "^16.4.5",
    "pino": "^9.4.0",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
