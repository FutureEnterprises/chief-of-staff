generator client {
  provider      = "prisma-client-js"
  output        = "../../../apps/web/.prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// USERS
// ============================================================

model User {
  id                    String    @id @default(cuid())
  clerkId               String    @unique
  email                 String    @unique
  name                  String
  avatarUrl             String?
  timezone              String    @default("America/New_York")
  morningCheckinTime    String    @default("08:00")
  nightCheckinTime      String    @default("21:00")
  briefingTime          String    @default("07:00")
  reminderIntensity     ReminderIntensity @default(STANDARD)
  emailBriefingEnabled  Boolean   @default(true)
  emailBriefingDays     String[]  @default(["MON", "TUE", "WED", "THU", "FRI"])
  planType              PlanType  @default(FREE)
  aiAssistsUsed         Int       @default(0)
  aiAssistsResetAt      DateTime  @default(now())
  trialEndsAt           DateTime?
  onboardingCompleted   Boolean   @default(false)
  expoPushToken         String?
  // Intent data (collected during onboarding)
  role                  String?
  useCase               String?
  referralSource        String?
  biggestGoal           String?
  failurePattern        String?
  lastActiveAt          DateTime  @default(now())
  // Execution Score & Streaks
  executionScore        Int       @default(0)
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  lastCompletionDate    DateTime?
  // Gamification
  level                 Int       @default(1)
  xp                    Int       @default(0)
  // Public profile
  profilePublic         Boolean   @default(false)
  profileSlug           String?   @unique
  // Autopilot Interruption System
  primaryWedge          PrimaryWedge  @default(PRODUCTIVITY)
  selfTrustScore        Int       @default(0)
  dangerWindows         Json?     // { "mon": ["21:00-23:00"], "sat": ["14:00-18:00"] }
  excuseStyle           ExcuseCategory?
  recoveryState         RecoveryState @default(ACTIVE)
  identityState         IdentityState @default(SLEEPWALKING)
  toneMode              ToneMode  @default(MENTOR)
  lastSlipAt            DateTime?
  slipsThisMonth        Int       @default(0)
  // Referral / growth
  referralCode          String?   @unique
  referredByUserId      String?
  // Stripe Connect for stakes
  stripeConnectId       String?
  // Integrations
  healthIntegrations    Json?     // { apple: true, google: false, calendar: "google" }
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tasks                 Task[]
  projects              Project[]
  tags                  Tag[]
  checkins              Checkin[]
  reminders             Reminder[]
  productivityEvents    ProductivityEvent[]
  aiInteractions        AiInteraction[]
  billingSubscription   BillingSubscription?
  emailBriefings        EmailBriefing[]
  badges                UserBadge[]
  challengeEntries      ChallengeEntry[]
  // Autopilot relations
  excuses               Excuse[]
  dangerWindowRecords   DangerWindow[]
  rescueSessions        RescueSession[]
  decisionLogs          DecisionLog[]
  commitments           Commitment[]
  slipRecords           SlipRecord[]
  scenarios             ScenarioSim[]
  // Accountability + stakes
  partnersAsOwner       AccountabilityPartner[] @relation("PartnerOwner")
  partnersAsPeer        AccountabilityPartner[] @relation("PartnerPeer")
  podMemberships        PodMember[]
  podsOwned             ChallengePod[]          @relation("PodOwner")
  stakes                Stake[]
  // Referrals
  referralsMade         Referral[]              @relation("Referrer")
  referralsReceived     Referral[]              @relation("Referred")

  @@map("users")
}

// ============================================================
// AUTOPILOT INTERRUPTION SYSTEM
// ============================================================

model Excuse {
  id           String          @id @default(cuid())
  userId       String
  text         String
  category     ExcuseCategory
  source       ExcuseSource    @default(CHAT)
  context      Json?
  createdAt    DateTime        @default(now())

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("excuses")
  @@index([userId, category])
  @@index([userId, createdAt])
}

enum ExcuseCategory {
  DELAY                // "I'll start tomorrow"
  REWARD               // "I deserve it"
  MINIMIZATION         // "one time won't matter"
  COLLAPSE             // "I already blew it"
  EXHAUSTION           // "I'm too tired"
  EXCEPTION            // "this week is weird"
  COMPENSATION         // "I'll make up for it later"
  SOCIAL_PRESSURE      // "I can't say no here"
}

enum ExcuseSource {
  CHAT
  DECISION
  RESCUE
  CHECKIN
}

model DangerWindow {
  id           String    @id @default(cuid())
  userId       String
  label        String    // "Late-night kitchen", "Friday happy hour"
  dayOfWeek    Int       // 0 (Sun) through 6 (Sat), -1 = all days
  startHour    Int       // 0-23 local time
  endHour      Int       // 0-23 local time
  triggerType  String?   // "stress", "social", "idle", "post-work"
  source       String    @default("user") // "user", "inferred"
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("danger_windows")
  @@index([userId, active])
}

model RescueSession {
  id            String         @id @default(cuid())
  userId        String
  trigger       RescueTrigger
  customText    String?
  intervention  Json           // AI response
  outcome       RescueOutcome  @default(PENDING)
  startedAt     DateTime       @default(now())
  resolvedAt    DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rescue_sessions")
  @@index([userId, startedAt])
}

enum RescueTrigger {
  BINGE_URGE
  DELIVERY_URGE
  NICOTINE_URGE
  ALCOHOL_URGE
  SKIP_WORKOUT
  SKIP_WEIGHIN
  ALREADY_SLIPPED
  SPIRALING
  DOOMSCROLL
  IMPULSE_SPEND
  OTHER
}

enum RescueOutcome {
  PENDING
  INTERRUPTED    // user pulled back
  SLIPPED        // user did the thing anyway
  UNRESOLVED     // no follow-up
}

model DecisionLog {
  id              String    @id @default(cuid())
  userId          String
  context         String    // what the user was deciding
  bestMove        String?
  worstCase       String?
  excuseDetected  String?
  smallestStep    String?
  userChose       String?
  outcome         String?   // "followed", "slipped", "unresolved"
  savedAsTaskId   String?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("decision_logs")
  @@index([userId, createdAt])
}

model Commitment {
  id            String              @id @default(cuid())
  userId        String
  rule          String              // "no food after 9 PM"
  domain        CommitmentDomain    @default(OTHER)
  frequency     CommitmentFrequency @default(DAILY)
  active        Boolean             @default(true)
  startedAt     DateTime            @default(now())
  endsAt        DateTime?
  stakeAmountCents Int?             // optional financial stake
  stakeId       String?             @unique
  keepCount     Int                 @default(0)
  breakCount    Int                 @default(0)
  lastCheckedAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  stake         Stake?              @relation(fields: [stakeId], references: [id])

  @@map("commitments")
  @@index([userId, active])
}

enum CommitmentDomain {
  FOOD
  EXERCISE
  CRAVING
  SLEEP
  SPENDING
  FOCUS
  RELATIONSHIP
  DIGITAL
  OTHER
}

enum CommitmentFrequency {
  DAILY
  WEEKLY
  ONE_TIME
}

model SlipRecord {
  id            String    @id @default(cuid())
  userId        String
  commitmentId  String?
  trigger       String?
  notes         String?
  recoverySteps Json?
  recoveredAt   DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("slip_records")
  @@index([userId, createdAt])
}

model ScenarioSim {
  id           String    @id @default(cuid())
  userId       String
  scenario     String    // the hypothetical
  immediate    String?
  behavioral   String?
  identityHit  String?
  alternative  String?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scenario_sims")
  @@index([userId, createdAt])
}

// ============================================================
// ACCOUNTABILITY + STAKES
// ============================================================

model AccountabilityPartner {
  id           String    @id @default(cuid())
  ownerId      String
  peerId       String?
  peerEmail    String    // for pending invites
  status       String    @default("pending") // "pending", "accepted", "declined"
  invitedAt    DateTime  @default(now())
  acceptedAt   DateTime?

  owner        User      @relation("PartnerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  peer         User?     @relation("PartnerPeer", fields: [peerId], references: [id], onDelete: SetNull)

  @@map("accountability_partners")
  @@index([ownerId])
  @@index([peerId])
  @@index([peerEmail])
}

model ChallengePod {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  ownerId      String
  joinCode     String    @unique
  maxMembers   Int       @default(5)
  durationDays Int       @default(14)
  startedAt    DateTime  @default(now())
  endsAt       DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  owner        User      @relation("PodOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      PodMember[]

  @@map("challenge_pods")
}

model PodMember {
  id         String   @id @default(cuid())
  podId      String
  userId     String
  joinedAt   DateTime @default(now())
  leftAt     DateTime?
  role       String   @default("member") // "owner", "member"

  pod        ChallengePod @relation(fields: [podId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([podId, userId])
  @@map("pod_members")
}

model Stake {
  id              String    @id @default(cuid())
  userId          String
  amountCents     Int
  currency        String    @default("USD")
  charityLabel    String    @default("GiveDirectly")
  stripeIntentId  String?   // Stripe payment intent (pre-auth)
  status          String    @default("active") // "active", "released", "charged", "refunded"
  chargedAt       DateTime?
  refundedAt      DateTime?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commitment      Commitment?

  @@map("stakes")
  @@index([userId])
}

model Referral {
  id              String    @id @default(cuid())
  referrerId      String
  referredId      String?   // null until signup
  referredEmail   String?
  code            String    @unique
  converted       Boolean   @default(false)
  convertedAt     DateTime?
  referrerCredit  Int       @default(0)  // cents
  referredCredit  Int       @default(0)
  createdAt       DateTime  @default(now())

  referrer        User      @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred        User?     @relation("Referred", fields: [referredId], references: [id], onDelete: SetNull)

  @@map("referrals")
  @@index([code])
  @@index([referrerId])
}

// ============================================================
// ENUMS — AUTOPILOT
// ============================================================

enum PrimaryWedge {
  PRODUCTIVITY
  WEIGHT_LOSS
  CRAVINGS
  DESTRUCTIVE_BEHAVIORS
  CONSISTENCY
  SPENDING
  FOCUS
}

enum RecoveryState {
  ACTIVE       // in normal flow
  SLIPPED      // just slipped, needs recovery
  RECOVERING   // in recovery protocol
  SILENT       // inactive 3+ days
}

enum IdentityState {
  SLEEPWALKING          // pre-awareness
  AVOIDANT              // dodging data
  RECOVERING            // post-slip
  UNSTABLE_BUT_TRYING   // trying, inconsistent
  INCREASINGLY_CONSCIOUS
  RESILIENT
  DISCIPLINED
  HIGH_SELF_TRUST
}

enum ToneMode {
  MENTOR        // warm, supportive
  STRATEGIST    // analytical, crisp
  NO_BS         // blunt, calls out avoidance
  BEAST         // high-pressure, confrontational
}

model Badge {
  id            String      @id @default(cuid())
  slug          String      @unique
  name          String
  description   String
  emoji         String
  category      String      // "streak", "completion", "enforcement", "social"
  xpReward      Int         @default(10)
  requirement   Json        // e.g. { type: "streak", value: 7 }
  createdAt     DateTime    @default(now())

  users         UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Challenge {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  description   String
  emoji         String
  durationDays  Int       // 7, 14, 30
  rules         Json      // { type: "daily_completions", min: 1 } or { type: "streak", min: 7 }
  xpReward      Int       @default(50)
  badgeSlug     String?   // badge awarded on completion
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  entries       ChallengeEntry[]

  @@map("challenges")
}

model ChallengeEntry {
  id            String    @id @default(cuid())
  userId        String
  challengeId   String
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  progress      Int       @default(0) // days completed
  status        String    @default("active") // "active", "completed", "failed"

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("challenge_entries")
}

enum PlanType {
  FREE
  CORE
  PLUS
  PREMIUM
  PRO          // legacy — maps to CORE for existing subscribers
  TEAM         // legacy — maps to PLUS for existing subscribers
}

enum ReminderIntensity {
  GENTLE
  STANDARD
  RELENTLESS
}

// ============================================================
// TASKS
// ============================================================

model Task {
  id                   String       @id @default(cuid())
  userId               String
  projectId            String?
  parentTaskId         String?
  title                String
  description          String?
  status               TaskStatus   @default(INBOX)
  priority             TaskPriority @default(MEDIUM)
  effortEstimate       EffortLevel?
  dueAt                DateTime?
  nextActionAt         DateTime?
  followUpRequired     Boolean      @default(false)
  nextFollowUpAt       DateTime?
  followUpIntervalDays Int?
  followUpMode         FollowUpMode?
  followUpStopCondition String?
  blockedReason        String?
  snoozedUntil         DateTime?
  completedAt          DateTime?
  archivedAt           DateTime?
  archiveReason        String?
  source               TaskSource   @default(MANUAL)
  aiConfidence         Float?
  aiSuggestions        Json?
  recurrenceRule       String?
  isRecurring          Boolean      @default(false)
  notes                String?
  lastTouchedAt        DateTime?
  snoozeCount          Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project              Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parentTask           Task?        @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks             Task[]       @relation("SubTasks")
  tags                 TaskTag[]
  reminders            Reminder[]
  productivityEvents   ProductivityEvent[]
  aiInteractions       AiInteraction[]

  @@map("tasks")
  @@index([userId, status])
  @@index([userId, status, dueAt])
  @@index([userId, status, completedAt])
  @@index([userId, status, priority])
  @@index([userId, followUpRequired, nextFollowUpAt])
  @@index([userId, dueAt])
  @@index([userId, nextFollowUpAt])
}

enum TaskStatus {
  INBOX
  OPEN
  PLANNED
  IN_PROGRESS
  BLOCKED
  WAITING
  SNOOZED
  COMPLETED
  ARCHIVED
}

enum TaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  SOMEDAY
}

enum EffortLevel {
  FIVE_MIN
  FIFTEEN_MIN
  THIRTY_MIN
  ONE_HOUR
  TWO_HOURS
  HALF_DAY
  FULL_DAY
  MULTI_DAY
}

enum FollowUpMode {
  ONE_TIME
  REPEATING
  ESCALATING
}

enum TaskSource {
  MANUAL
  AI_CHAT
  AI_EXTRACTION
  EMAIL
  CHECKIN
  API
}

// ============================================================
// PROJECTS
// ============================================================

model Project {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  color       String?
  icon        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@map("projects")
  @@index([userId])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
  ON_HOLD
}

// ============================================================
// TAGS
// ============================================================

model Tag {
  id          String   @id @default(cuid())
  userId      String
  name        String
  parentTagId String?
  color       String?
  icon        String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentTag   Tag?     @relation("SubTags", fields: [parentTagId], references: [id], onDelete: SetNull)
  subTags     Tag[]    @relation("SubTags")
  tasks       TaskTag[]

  @@map("tags")
  @@unique([userId, name])
}

model TaskTag {
  taskId String
  tagId  String

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

// ============================================================
// CHECK-INS
// ============================================================

model Checkin {
  id            String       @id @default(cuid())
  userId        String
  type          CheckinType
  promptedAt    DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  summaryJson   Json?
  rawTranscript Json?
  taskIds       String[]
  createdAt     DateTime     @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("checkins")
  @@index([userId, type])
}

enum CheckinType {
  MORNING
  NIGHT
}

// ============================================================
// REMINDERS
// ============================================================

model Reminder {
  id             String         @id @default(cuid())
  userId         String
  taskId         String?
  reminderType   ReminderType
  scheduledAt    DateTime
  sentAt         DateTime?
  channel        ReminderChannel
  status         ReminderStatus  @default(PENDING)
  metadataJson   Json?
  createdAt      DateTime        @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  task           Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("reminders")
  @@index([scheduledAt, status])
}

enum ReminderType {
  DUE_SOON
  DUE_NOW
  OVERDUE
  FOLLOW_UP
  MORNING_CHECKIN
  NIGHT_CHECKIN
  DAILY_BRIEFING
  SNOOZE_END
  FOLLOW_UP_ESCALATED
  WAITING_STALE
  WEEKLY_REVIEW
  OVERDUE_ESCALATED
}

enum ReminderChannel {
  EMAIL
  PUSH
  IN_APP
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// ============================================================
// PRODUCTIVITY EVENTS
// ============================================================

model ProductivityEvent {
  id           String    @id @default(cuid())
  userId       String
  taskId       String?
  eventType    EventType
  eventValue   String?
  metadataJson Json?
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task         Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("productivity_events")
  @@index([userId, createdAt])
  @@index([userId, eventType])
}

enum EventType {
  TASK_CREATED
  TASK_COMPLETED
  TASK_SNOOZED
  TASK_OVERDUE
  TASK_ARCHIVED
  TASK_BLOCKED
  FOLLOW_UP_COMPLETED
  CHECKIN_STARTED
  CHECKIN_COMPLETED
  AI_BREAKDOWN_USED
  AI_SIMPLIFY_USED
  PAYWALL_SEEN
  UPGRADE_STARTED
  UPGRADE_COMPLETED
  TASK_REOPENED
  TASK_DECOMPOSED
  DUE_DATE_CHANGED
  FOLLOW_UP_CREATED
  FOLLOW_UP_ESCALATED
  SNOOZE_EXPIRED
  ONBOARDING_COMPLETED
  TRIAL_STARTED
  NOTIFICATION_OPENED
  CHURN_EMAIL_SENT
  FEATURE_USED
  ASSESSMENT_RUN
  CHAT_SESSION
  MORNING_REVIEW
  NIGHT_REVIEW
  STREAK_MILESTONE
  WEEKLY_REPORT_SENT
  BADGE_EARNED
  LEVEL_UP
  CHALLENGE_STARTED
  CHALLENGE_COMPLETED
  CHALLENGE_FAILED
  SLIP_LOGGED
  SLIP_RECOVERED
  RESCUE_TRIGGERED
  RESCUE_RESOLVED
  DECISION_MADE
  EXCUSE_DETECTED
  DANGER_WINDOW_CROSSED
  AUTOPILOT_INTERRUPTED
  COMMITMENT_CREATED
  COMMITMENT_KEPT
  COMMITMENT_BROKEN
  STAKE_PLACED
  STAKE_CHARGED
  STAKE_REFUNDED
  PARTNER_INVITED
  PARTNER_ACCEPTED
  POD_CREATED
  POD_JOINED
  SCENARIO_SIMULATED
  REFERRAL_SENT
  REFERRAL_CONVERTED
  IDENTITY_CHANGED
}

// ============================================================
// AI INTERACTIONS
// ============================================================

model AiInteraction {
  id              String          @id @default(cuid())
  userId          String
  taskId          String?
  interactionType AiInteractionType
  provider        String
  model           String
  inputText       String
  outputJson      Json
  tokenUsage      Json?
  durationMs      Int?
  createdAt       DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("ai_interactions")
  @@index([userId, createdAt])
}

enum AiInteractionType {
  TASK_EXTRACTION
  TASK_DECOMPOSITION
  TASK_SIMPLIFY
  TASK_REWRITE
  PRIORITIZATION
  DAILY_SUMMARY
  PRODUCTIVITY_COACHING
  CHAT
}

// ============================================================
// EMAIL BRIEFINGS
// ============================================================

model EmailBriefing {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  htmlContent String
  sentAt      DateTime?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_briefings")
  @@index([userId, createdAt])
}

// ============================================================
// BILLING
// ============================================================

model BillingSubscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  provider             String    @default("stripe")
  planType             PlanType  @default(FREE)
  status               String    @default("active")
  startedAt            DateTime  @default(now())
  renewsAt             DateTime?
  cancelledAt          DateTime?
  trialEndsAt          DateTime?
  metadataJson         Json?

  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_subscriptions")
}
