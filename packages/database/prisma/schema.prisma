/**
 * MarketingPost — a draft / approved / posted marketing artifact.
 * Drafts are generated via apps/web/src/lib/marketing/templates.ts
 * (composePrompt) and persisted here so the founder can edit, approve,
 * and (eventually) auto-post via Phase-3 platform adapters.
 * Statuses move in roughly this order:
 * DRAFT → APPROVED → POSTED
 * DRAFT → REJECTED (terminal)
 * APPROVED → ERRORED (auto-post failure; can flip back to APPROVED)
 * finalBody is the human-edited version of draftBody. When null, the
 * draftBody is what gets posted. approvedBy stores the Clerk userId of
 * whoever flipped the post to APPROVED (single-admin model for v1).
 */
model MarketingPost {
  id              String              @id @default(cuid())
  platform        MarketingPlatform
  archetype       String? // family slug or "category-launch" / "why-now" / "product-update"
  topic           String              @db.Text
  draftBody       String              @db.Text
  finalBody       String?             @db.Text
  status          MarketingPostStatus @default(DRAFT)
  approvedBy      String? // Clerk userId of the approver
  postedAt        DateTime?
  postedUrl       String?
  rejectionReason String?             @db.Text
  generatedAt     DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  model           String              @default("sonnet") // "sonnet" | "haiku"

  @@index([status, platform])
  @@index([archetype])
  @@index([generatedAt])
  @@map("marketing_posts")
}

enum MarketingPlatform {
  REDDIT
  TWITTER_THREAD
  TWITTER_SINGLE
  THREADS
  LINKEDIN
  INDIEHACKERS
  PRODUCTHUNT
  HACKERNEWS
  NEWSLETTER
}

enum MarketingPostStatus {
  DRAFT
  APPROVED
  REJECTED
  POSTED
  ERRORED
}

// ============================================================
// SCHEDULED INTERRUPTS — first-hour felt-interrupt funnel
//
// Per the May 2026 product blueprint: the highest-leverage product
// change is "90-second onboarding with first-hour scheduled interrupt."
// Anonymous audit-takers leave with a real interrupt locked into their
// predicted danger window for tonight (or tomorrow if the window has
// already passed). The cron at /api/cron/scheduled-interrupts walks
// PENDING rows whose scheduledFor <= now and fires SMS + email.
//
// Distinct from Reminder (signed-in users only, task-scoped) and
// SmsSignup (one-shot intro from /catch-me — no archetype payload).
// This row owns the full script the audit produced, so the interrupt
// that lands is the exact wedge/window/script the user just identified.
// ============================================================

model ScheduledInterrupt {
  id              String                   @id @default(cuid())
  phoneNumber     String?
  email           String?
  archetypeFamily String // family slug, e.g. "the-9pm-negotiator"
  wedge           String
  window          String
  script          String
  scheduledFor    DateTime
  timezone        String
  status          ScheduledInterruptStatus @default(PENDING)
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime                 @default(now())

  @@index([status, scheduledFor])
  @@map("scheduled_interrupts")
}

enum ScheduledInterruptStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

// ============================================================
// CUSTOM CHECK-IN SCHEDULES — user-defined recurring nudges.
//
// Distinct from ScheduledInterrupt (one-shot, system-generated, anonymous)
// and from User.morningCheckinTime / User.nightCheckinTime (two legacy
// daily slots, system-controlled). This table is ADDITIVE: it lets a
// signed-in user define their own recurring cadences in addition to the
// legacy morning/night. Use cases the founder named: "hourly" (e.g.
// every 4 hours within a waking window), "nightly" (daily at a chosen
// PM time), "monthly" (review cadence), plus weekly.
//
// Fired by /api/cron/custom-checkins on a 1-minute tick. The cron picks
// rows where active = true AND nextFiresAt <= now + 1 min lookahead,
// sends via the row's channel, then advances nextFiresAt via the
// computeNextFire helper in lib/services/checkin-schedule.service.ts.
//
// Per-cadence time fields are intentionally nullable + cadence-shaped
// (rather than a single cron-expression string) so the settings UI can
// stay declarative — no cron literacy required and no eval-style
// expression surface to defend against.

model CheckinSchedule {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // User-visible label, e.g. "Afternoon walk reminder" or "Sunday review".
  // Free text but capped at 80 chars at the API layer.
  label String

  cadence CheckinCadence
  channel CheckinChannel @default(EMAIL)

  // For HOURLY cadence — fires every {intervalHours} hours INSIDE the
  // [windowStart, windowEnd] local-time window. Both stored as "HH:MM"
  // strings interpreted in the user's timezone. windowStart < windowEnd
  // assumed; e.g. "09:00" / "21:00" → 9 AM through 9 PM only.
  intervalHours Int?
  windowStart   String?
  windowEnd     String?

  // For DAILY cadence — fires once per day at this local time.
  dailyTime String?

  // For WEEKLY cadence — day-of-week (0=Sun..6=Sat) at local time.
  weeklyDay  Int?
  weeklyTime String?

  // For MONTHLY cadence — day-of-month (1..28 enforced at API; 29-31
  // skipped on months that don't have them) at local time.
  monthlyDay  Int?
  monthlyTime String?

  active      Boolean   @default(true)
  lastFiredAt DateTime?
  nextFiresAt DateTime?

  // Optional short message body the user wants delivered. If null the
  // service falls back to a default per-cadence prompt.
  message String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Inbound replies linked back to this schedule via the 12-hour window
  // heuristic in the Twilio / Resend inbound webhooks.
  inboundMessages InboundMessage[]

  @@index([userId, active])
  @@index([active, nextFiresAt])
  @@map("checkin_schedules")
}

enum CheckinCadence {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum CheckinChannel {
  EMAIL
  SMS
}

// ============================================================
// PHASE 1-4 MOAT LAYER
//
// New tables for the passive-signal stack (SignalCluster, PredictionModel),
// the daily-number ritual (DailyNumber), pre-approved redirects
// (RedirectChoice), family/couples accountability pods (Pod, PodMember
// — distinct from the legacy ChallengePodMember above), and Microsoft
// Teams B2B provisioning (TeamsWorkspace).
//
// Eight backend agents in Wave 2 import these types. See migration
// 20260521010000_phase_1_4_models for the corresponding SQL.
// ============================================================

/**
 * SignalCluster — multivariate passive-signal snapshot captured at
 * moment T. Combines physiological (HRV), behavioral (sedentary time,
 * unlock rate, screen-on), and contextual (location, time, meeting
 * load) signals into one row. Outcome fields are set retroactively
 * once we observe whether a slip happened within the 30/60-min window
 * — that paired data is what trains the per-user PredictionModel.
 */
model SignalCluster {
  id         String   @id @default(cuid())
  userId     String
  capturedAt DateTime @default(now())

  // Physiological
  hrvSamples  Json? // last N HRV samples + computed delta
  hrvBaseline Float? // user's rolling baseline
  hrvDeltaPct Float? // % drop from baseline over last 60min

  // Behavioral
  sedentaryMins   Int? // contiguous sedentary minutes
  unlockRateDelta Float? // % change in phone unlock rate vs daily avg
  screenOnMins    Int? // continuous screen-on duration

  // Contextual
  locationKind   String? // 'home' | 'kitchen' | 'work' | 'unknown'
  dayOfWeek      Int
  hourOfDay      Int
  meetingDensity Int? // # meetings today
  weekdayStress  String? // 'high' | 'medium' | 'low' (derived)

  // Outcome (set retroactively when slip or non-slip is observed)
  outcomeWithin30Min String? // 'slip' | 'no_slip' | null (unresolved)
  outcomeWithin60Min String?
  outcomeRecordedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capturedAt])
  @@index([userId, outcomeWithin30Min])
  @@map("signal_clusters")
}

/**
 * PredictionModel — per-user logistic regression coefficients trained
 * from paired SignalCluster outcomes. Coefficients are JSON for
 * forward compatibility with future model types (boosted trees, small
 * neural nets) without requiring a schema migration. Exactly one model
 * per user should be `active = true` at a time; older versions are
 * retained for rollback and A/B comparison.
 */
model PredictionModel {
  id      String @id @default(cuid())
  userId  String
  version Int    @default(1)

  // Logistic regression coefficients (JSON for forward compatibility)
  coefficients Json // { hrvDeltaPct: -0.42, sedentaryMins: 0.18, ... }
  intercept    Float

  // Training metadata
  trainedOn   DateTime @default(now())
  sampleCount Int // N paired examples used to train
  accuracy    Float? // measured against held-out set (if any)
  precision   Float?
  recall      Float?

  // Active flag — exactly one model active per user at a time
  active Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, version])
  @@index([userId, active])
  @@map("prediction_models")
}

/**
 * DailyNumber — the Wrapped-style daily ritual record. One row per
 * user per local day; stores the single number (selfTrustScore) and
 * single sentence (identitySentence) that ship to the home screen and
 * the share card. `shareCode` powers the public share URL so the link
 * isn't guessable from the row id.
 */
model DailyNumber {
  id     String   @id @default(cuid())
  userId String
  date   DateTime // user-local date at midnight UTC

  // The single number that ships
  selfTrustScore Int // 0-100
  selfTrustDelta Int // change from yesterday

  // The single sentence
  identitySentence String // "Day 47. You held a 9 PM moment last night."
  dayNumber        Int // day N of usage

  // Pattern context
  archetype       String? // family slug at time of computation
  topWindowHeld   String? // last night's window the user held, if any
  topWindowMissed String? // last night's window the user missed, if any

  // Share tracking
  shareCount   Int       @default(0)
  lastSharedAt DateTime?
  shareCode    String    @unique @default(cuid())

  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([shareCode])
  @@map("daily_numbers")
}

/**
 * RedirectChoice — the user's 3 pre-approved alternatives picked at
 * audit time. When the autopilot fires an interrupt, the rescue UI
 * surfaces these instead of generic suggestions. servedCount and
 * acceptedCount feed a lazy effectiveness computation so the top-rank
 * slot can rotate toward what actually works for this user.
 */
model RedirectChoice {
  id     String @id @default(cuid())
  userId String

  rank     Int // 1, 2, or 3 (priority ordering)
  text     String // "Text the person I've been meaning to text"
  category String? // 'connection' | 'creative' | 'physical' | 'rest' | 'other'

  // How well it has worked in practice
  servedCount      Int    @default(0) // times surfaced as intervention
  acceptedCount    Int    @default(0) // times user took the redirect
  effectivenessPct Float? // computed lazily

  createdAt  DateTime  @default(now())
  archivedAt DateTime?
  active     Boolean   @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@map("redirect_choices")
}

/**
 * Pod — a family or couples accountability pod. Distinct from the
 * legacy `ChallengePod` (14/30-day cohort challenges); a Pod is a
 * persistent small group (≤6 members default) where members opt into
 * a shareLevel that controls how much of their pattern data the rest
 * of the pod can see. Invite is by `inviteCode` (random, not the id).
 */
model Pod {
  id          String @id @default(cuid())
  name        String // "The Smiths" or whatever the owner sets
  createdById String

  // Privacy
  inviteCode String @unique @default(cuid())
  maxMembers Int    @default(6)

  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  members PodMember[]

  @@index([createdById])
  @@index([inviteCode])
  @@map("pods")
}

/**
 * PodMember — membership row joining a User to a Pod. shareLevel is
 * the per-member privacy dial: 'counts_only' (just totals), 'patterns'
 * (archetype + windows), 'full' (the daily number too). archetype is
 * surfaced to other pod members at the patterns/full level.
 * Distinct from the legacy `ChallengePodMember` above, which backs the
 * older time-boxed cohort challenges.
 */
model PodMember {
  id     String @id @default(cuid())
  podId  String // shared by all members of one pod
  userId String

  role       String  @default("member") // 'owner' | 'member'
  archetype  String? // visible to other pod members
  shareLevel String  @default("counts_only") // 'counts_only' | 'patterns' | 'full'

  invitedBy String? // userId of the inviter
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  active    Boolean   @default(true)

  pod  Pod  @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([podId, userId])
  @@index([podId])
  @@index([userId, active])
  @@map("pod_members")
}

/**
 * TeamsWorkspace — Microsoft Teams enterprise mapping. One row per
 * Azure AD tenant that has installed the Teams app. defaultPlan is
 * the entitlement applied to users provisioned via SCIM or just-in-
 * time SSO. paymentStatus tracks the per-tenant subscription independent
 * of any single user's billing.
 */
model TeamsWorkspace {
  id            String @id @default(cuid())
  tenantId      String @unique // Microsoft Azure AD tenant
  workspaceName String

  // Provisioning
  installedById String // userId of the IT admin who installed
  installedAt   DateTime @default(now())

  // Configuration
  defaultPlan String  @default("CORE") // entitlement for newly-provisioned users
  ssoProvider String  @default("azure_ad")
  scimEnabled Boolean @default(false)

  // Status
  active        Boolean @default(true)
  paymentStatus String  @default("pending") // 'pending' | 'paid' | 'overdue' | 'cancelled'

  @@index([tenantId])
  @@map("teams_workspaces")
}

/**
 * TeamsUserAuth — per-user Microsoft Graph OAuth tokens.
 * Distinct from TeamsWorkspace (one row per tenant, written at admin-
 * consent time) and from the Bot Framework credentials (which are
 * tenant-spanning bot identity, not per-user). This row holds the
 * delegated Graph access — the access + refresh token the user granted
 * COYL so the /api/cron/teams-graph-pull poller can read their calendar
 * and email and auto-fire the four archetype interrupt classes.
 * Tokens are encrypted at rest via encryptToken() from dexcom.ts
 * (AES-256-GCM, key from INTEGRATION_ENCRYPTION_KEY). The cron's "due
 * for refresh" scan uses the (tenantId, tokenExpiresAt) index.
 * scopesGranted is the subset Microsoft actually returned in the token
 * response — we ask for Calendars.Read + Mail.Read + User.Read +
 * offline_access but the user may consent to fewer, and the cron skips
 * signal classes whose scope isn't granted.
 */
model TeamsUserAuth {
  id                 String    @id @default(cuid())
  userId             String    @unique
  tenantId           String
  accessTokenCipher  String    @db.Text
  refreshTokenCipher String    @db.Text
  tokenExpiresAt     DateTime
  scopesGranted      String[] // e.g. ["Calendars.Read", "Mail.Read", "User.Read"]
  lastRefreshedAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, tokenExpiresAt])
  @@map("teams_user_auths")
}

// ============================================================
// EAP + PAP COORDINATOR DATA SUBSTRATE
//
// Data layer for the proactive AI infrastructure. Five Wave 2 cloud
// agents import these types: auth, EAP core, PAP core, coordinator
// logic, and admin dashboard.
//
// EAP (Edge AI Protocol) = LLM-emitted device action requests +
//   multi-device orchestrations + sensor pub/sub.
// PAP (Proactive AI Protocol) = LLM-emitted intervention proposals
//   scoped to user-level moments rather than specific devices.
// Coordinator owns scope grants, audit log, and emergency panic state.
//
// See migration 20260522010000_eap_pap_coordinator for the SQL.
// ============================================================

/**
 * LLMPartner — registered foundation-lab partner (e.g. Anthropic
 * Claude Sonnet 3.7, OpenAI o3, Google Gemini 2.5). Every PAP
 * proposal / EAP action / sensor subscription is attributable to a
 * partner. API keys are bcrypt-hashed; only the last four chars are
 * stored in plaintext for display in the admin UI.
 */
model LLMPartner {
  id        String @id @default(cuid())
  slug      String @unique // 'anthropic-claude-sonnet-3.7'
  name      String // 'Anthropic Claude Sonnet 3.7'
  publisher String // 'Anthropic'

  // Auth — PAP (Partner-Authority Protocol) key.
  // Wire format: coyl_pap_<id>_<keySecret>.
  apiKeyHash       String  @unique // bcrypt of PAP API key, never store plaintext
  apiKeyLastFour   String // last 4 chars for display only
  active           Boolean @default(true)
  rateLimitPerHour Int     @default(1000)

  // Auth — UAP (User-Authority Protocol) key.
  // Distinct from the PAP key above so a single partner row can hold
  // either or both. Nullable: partners onboarded for PAP only have no
  // UAP key minted yet. Wire format: coyl_uap_<id>_<keySecret>.
  // Verified by lib/uap/uap-partner-auth.ts.
  uapApiKeyHash String?

  // Commercial
  pricingTier   String   @default("usage") // 'free' | 'usage' | 'enterprise' | 'strategic'
  bundledScopes String[] // default scope packages they can request

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposals      PAPProposal[]
  actionRequests ActionRequest[]
  scopeGrants    ScopeGrant[]
  subscriptions  SensorSubscription[]
  orchestrations Orchestration[]
  // UAP (User-Authority Protocol) standing-authority grants issued to
  // this partner. See docs/protocol/UAP-0.1.md.
  uapGrants      UAPGrant[]

  @@index([slug])
  @@index([active])
  @@map("llm_partners")
}

/**
 * Device — a registered device in the user's fleet. The capability
 * manifest is JSON so per-device-class shape (Apple Watch vs browser
 * extension vs macOS laptop) doesn't require a migration. `paired`
 * gates whether the device can receive actions; `online` + lastSeenAt
 * power the offline-tolerant action queue.
 */
model Device {
  id          String  @id @default(cuid())
  userId      String
  deviceClass String // 'ios_phone' | 'apple_watch' | 'macos_laptop' | 'browser_extension' | etc.
  model       String? // 'iPhone 16 Pro'
  os          String? // 'iOS 17.4'

  // Identity
  deviceFingerprint String    @unique // hashed per-device identifier
  paired            Boolean   @default(false)
  pairedAt          DateTime?

  // Device-scoped machine credential (EAP §1). Minted at first
  // /device/register and returned to the coordinator exactly once
  // (plaintext is never persisted — only the bcrypt hash). The
  // coordinator presents it as `Authorization: Bearer
  // coyl_eap_<deviceId>_<secret>` on its own machine-auth calls
  // (pending-actions poll + sensor publish). Stable across manifest
  // re-registers so a stored token keeps working; null until the
  // first register that mints it.
  deviceTokenHash     String? // bcrypt of the device token secret, never store plaintext
  deviceTokenLastFour String? // last 4 chars of the secret, for display/debug only

  // Capabilities (JSON because per-device-class shape varies)
  manifestJson     Json // { sensors: [], actuators: [], userGrantedScopes: [] }
  operationalState Json? // last-known battery / DND / foreground app

  // State
  online     Boolean  @default(false)
  lastSeenAt DateTime @default(now())
  pushToken  String? // for waking the device when offline-tolerant action queued

  // Latest sensor snapshot (EAP §5). The coordinator POSTs a full
  // snapshot every 60s to /sensor/<deviceId>/publish; we keep only
  // the most recent here (the SensorSubscription fan-out webhook is
  // the durable history channel). lastSensorSnapshot is the raw
  // { screen_state, battery, foreground_app, ... } object the device
  // sent; lastSensorAt is when we received it.
  lastSensorSnapshot Json? // most-recent published sensor snapshot
  lastSensorAt       DateTime? // when the snapshot above was received

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionRequests ActionRequest[]
  subscriptions  SensorSubscription[]

  @@index([userId, paired])
  @@index([deviceFingerprint])
  @@map("devices")
}

/**
 * ScopeGrant — per-LLM × per-user × per-scope authorization. Each
 * grant is tied to a consent-screen-version so we can re-prompt if
 * the consent UI for a scope materially changes. `bundleKey` lets us
 * track whether a scope was granted individually or via a bundle
 * (e.g. 'behavioral_package'). Revocations are soft (revokedAt) for
 * audit; the unique constraint allows re-grants by toggling `active`.
 */
model ScopeGrant {
  id           String @id @default(cuid())
  userId       String
  llmPartnerId String

  scope     String // 'edge:watch:haptic' | 'proactive_food' | etc.
  bundleKey String? // if granted via a bundle ('behavioral_package'), reference the bundle

  grantedAt DateTime  @default(now())
  expiresAt DateTime? // null = no expiration
  revokedAt DateTime?
  active    Boolean   @default(true)

  // Audit
  consentScreenVersion String // 'v1.2' — which consent UI fired the grant
  ipAddress            String?
  userAgent            String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  llmPartner LLMPartner @relation(fields: [llmPartnerId], references: [id], onDelete: Cascade)

  @@unique([userId, llmPartnerId, scope])
  @@index([userId, active])
  @@index([llmPartnerId, active])
  @@map("scope_grants")
}

/**
 * PAPProposal — LLM-emitted intervention proposal (PAP layer). The
 * LLM provides `proposalKey` for idempotency. Coordinator records the
 * decision (allowed/denied/queued) + scheduledFor; on execution the
 * `executionToken` is minted (unique, single-use) and the outcome is
 * back-filled when the user tags it (`caught_me`, `ignored`, etc.).
 * Distinct from ActionRequest in that a proposal is moment-scoped
 * (the user) and may fan out into multiple ActionRequests downstream.
 */
model PAPProposal {
  id          String @id @default(cuid())
  proposalKey String @unique // LLM-provided idempotency key

  llmPartnerId String
  userId       String

  // Proposal shape
  scopeRequested String[] // multiple scopes possible
  actionJson     Json // { kind, modality, mode, headline, subhead, etc. }
  contextJson    Json // { trigger, confidence, reasoning }

  // Coordinator decision
  decision       String // 'allowed' | 'denied' | 'queued'
  decisionReason String? // 'rate_limited' | 'scope_not_granted' | etc.
  scheduledFor   DateTime?

  // Execution
  executionToken String?   @unique
  executedAt     DateTime?

  // Outcome
  outcome       String? // 'caught_me' | 'ignored' | 'snoozed' | etc.
  outcomeSource String? // 'user_tag' | 'inferred' | 'system_timeout'
  outcomeAt     DateTime?

  createdAt DateTime @default(now())

  llmPartner LLMPartner @relation(fields: [llmPartnerId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([llmPartnerId, createdAt])
  @@index([decision])
  @@map("pap_proposals")
}

/**
 * ActionRequest — LLM-emitted device action request (EAP layer). A
 * single actuator (haptic, push, TTS) on a single device, scoped to
 * a single scope. `orchestrationId` is nullable: single-action
 * requests have no parent; multi-device flows link back to an
 * Orchestration row. Outcome is observable (executed/failed/rejected
 * /expired) — userInteracted flips true when the user engages with
 * the resulting UI surface.
 */
model ActionRequest {
  id        String @id @default(cuid())
  actionKey String @unique // LLM-provided idempotency key

  llmPartnerId String
  userId       String
  deviceId     String

  // Action shape
  actuator       String // 'haptic' | 'push_notification' | 'voice_tts' | etc.
  paramsJson     Json
  scopeRequested String // single scope per ActionRequest
  reasoning      String // user-readable rationale (for audit + UI)
  confidence     Float?

  // Coordinator decision
  decision       String // 'allowed' | 'denied' | 'queued' | 'pending_confirmation'
  decisionReason String?

  // Execution
  executionToken String?   @unique
  executedAt     DateTime?

  // Outcome
  outcome        String? // 'executed' | 'failed' | 'rejected' | 'expired'
  outcomeReason  String?
  outcomeAt      DateTime?
  userInteracted Boolean   @default(false)

  // Orchestration parent (nullable — single-action requests have no parent)
  orchestrationId String?

  createdAt DateTime @default(now())

  llmPartner    LLMPartner     @relation(fields: [llmPartnerId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  device        Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  orchestration Orchestration? @relation(fields: [orchestrationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([deviceId, createdAt])
  @@index([llmPartnerId, createdAt])
  @@map("action_requests")
}

/**
 * Orchestration — multi-device composite flow (e.g. "haptic on watch
 * + TTS on phone + dim screen on laptop"). `atomicity` controls
 * rollback semantics: 'all_or_none' rolls back partial executions if
 * any child action fails; 'best_effort' fires each child
 * independently. `decision` resolves to 'allowed' / 'denied' /
 * 'partial' once the coordinator has scored all child actions.
 */
model Orchestration {
  id               String @id @default(cuid())
  orchestrationKey String @unique

  llmPartnerId String
  userId       String

  atomicity String @default("best_effort") // 'all_or_none' | 'best_effort'
  decision  String // 'allowed' | 'denied' | 'partial'

  // Status
  startedAt    DateTime?
  completedAt  DateTime?
  rolledBackAt DateTime?

  createdAt DateTime @default(now())

  llmPartner LLMPartner      @relation(fields: [llmPartnerId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions    ActionRequest[]

  @@index([userId, createdAt])
  @@index([llmPartnerId, createdAt])
  @@map("orchestrations")
}

/**
 * SensorSubscription — pub/sub sensor stream. LLM partners register
 * for sensor deltas (HRV drop, motion, geofence enter/exit) and the
 * coordinator POSTs to `webhookUrl` HMAC-signed with `webhookSecret`
 * when the filter matches. `failureCount` is incremented on each
 * non-2xx response; subscriptions auto-deactivate after a threshold.
 * `deviceId` is nullable to allow "any device with this sensor".
 */
model SensorSubscription {
  id              String @id @default(cuid())
  subscriptionKey String @unique

  llmPartnerId String
  userId       String
  deviceId     String? // null = any device with this sensor

  sensor     String // 'hrv_proxy' | 'motion' | 'location_geofence' | etc.
  filterJson Json // { deltaPctMin: 15, directionDown: true } etc.

  webhookUrl    String
  webhookSecret String // HMAC secret for outgoing webhook signing

  rateLimitPerHour Int       @default(60)
  active           Boolean   @default(true)
  failureCount     Int       @default(0)
  lastFiredAt      DateTime?

  createdAt DateTime @default(now())

  llmPartner LLMPartner @relation(fields: [llmPartnerId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  device     Device?    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([llmPartnerId, active])
  @@map("sensor_subscriptions")
}

/**
 * EAPAuditEntry — append-only audit log for proposals, actions,
 * scope grants/revokes, and panic triggers. No foreign-key relation
 * back to user/llm_partner because audit rows must outlive the
 * deletion of their referent (compliance / forensic trail). The
 * referenceId is a soft pointer (ActionRequest.id / ScopeGrant.id /
 * etc.) interpreted in light of `eventKind`.
 */
model EAPAuditEntry {
  id           String  @id @default(cuid())
  userId       String
  llmPartnerId String?

  eventKind   String // 'proposal_received' | 'action_executed' | 'scope_granted' | 'scope_revoked' | 'panic_triggered' | etc.
  referenceId String? // foreign id (ActionRequest.id / ScopeGrant.id / etc.)

  payloadJson Json
  ipAddress   String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([llmPartnerId, createdAt])
  @@index([eventKind, createdAt])
  @@map("eap_audit_entries")
}

/**
 * PanicState — per-user emergency revoke state. When the user trips
 * the panic switch (24h default expiry), every LLM partner sees all
 * of that user's scope grants as inactive until `expiresAt`. Exactly
 * one row per user (unique constraint on userId); coordinator
 * upserts on each panic toggle.
 */
model PanicState {
  id     String @id @default(cuid())
  userId String @unique

  active      Boolean   @default(false)
  activatedAt DateTime?
  expiresAt   DateTime?
  reason      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("panic_states")
}

/**
 * CronHeartbeat — last successful run per named cron / workflow.
 * Surfaces staleness on the admin dashboard. Workflows write their
 * final result here so an operator can spot a wedged job before the
 * next scheduled invocation. One row per named job (upserted).
 * Seeded by /api/cron/* routes that have migrated to the Workflow
 * DevKit (see workflows/*.ts). Best-effort crons stay in their own
 * audit channels until they migrate too.
 */
model CronHeartbeat {
  name        String   @id
  lastRunAt   DateTime
  lastRunMeta Json?

  @@map("cron_heartbeats")
}

/**
 * AuditLead — anonymous /audit visitors who entered an email to have
 * their result delivered. Lower-commitment than the ScheduleInterrupt
 * flow (which captures phone or email AND books an actual SMS/email
 * for the next danger window). This row is "email me this so I can
 * come back" — the right top-of-funnel for viral acquisition where
 * most visitors won't yet commit to a scheduled interrupt.
 * convertedUserId is populated when the lead later signs up — the
 * audit-archetype carries through onboarding so the user lands in
 * /today already pattern-mapped.
 */
model AuditLead {
  id              String    @id @default(cuid())
  email           String
  archetypeFamily String
  archetypeSlug   String?
  wedge           String
  window          String
  script          String
  source          String?
  userAgent       String?
  ipHash          String?
  emailSentAt     DateTime?
  emailMessageId  String?
  convertedUserId String?
  createdAt       DateTime  @default(now())

  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@index([archetypeFamily])
  @@index([source])
  @@map("audit_leads")
}

/**
 * AuditFunnelEvent — anonymous /audit funnel telemetry. The four-stage
 * funnel: started → completed → email_captured → signup_started.
 * Separate from ProductivityEvent (which needs a userId; audit
 * visitors are mostly anonymous) and separate from AuditLead (which
 * only fires at the email-captured stage and misses the drop-offs
 * before it). sessionId ties the funnel together across requests.
 */
model AuditFunnelEvent {
  id              String   @id @default(cuid())
  sessionId       String
  /// One of: 'started' | 'completed' | 'email_captured' | 'signup_started'
  kind            String
  archetypeFamily String?
  archetypeSlug   String?
  wedge           String?
  window          String?
  script          String?
  source          String?
  userAgent       String?
  ipHash          String?
  createdAt       DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([kind])
  @@index([sessionId])
  @@index([archetypeFamily])
  @@map("audit_funnel_events")
}

/**
 * RetentionSnapshot — daily cohort retention point-in-time record.
 * Written by the daily retention-snapshot cron at 04:00 UTC. One row
 * per (snapshotDate, cohortKind) — cohortKind in {'D1','D7','D14','D30'}.
 * The admin retention dashboard reads the last 30 snapshots per
 * cohort to show trend, not just the live point-in-time.
 * Cohort definitions, relative to snapshotDate S:
 * D1  — users registered (S-2, S-1], active in (S-1, S]
 * D7  — users registered (S-14, S-7], active in (S-7, S]
 * D14 — users registered (S-28, S-14], active in (S-14, S]
 * D30 — users registered (S-60, S-30], active in (S-30, S]
 */
model RetentionSnapshot {
  id            String   @id @default(cuid())
  snapshotDate  DateTime @db.Date
  cohortKind    String
  cohortSize    Int
  retainedCount Int
  retentionPct  Float
  cohortStartAt DateTime
  cohortEndAt   DateTime
  createdAt     DateTime @default(now())

  @@unique([snapshotDate, cohortKind])
  @@index([snapshotDate(sort: Desc)])
  @@index([cohortKind])
  @@map("retention_snapshots")
}

// ============================================================
// UAP — USER-AUTHORITY PROTOCOL v0.1
// ============================================================
//
// Standing-authority layer for autonomous LLM action without
// per-action consent. See docs/protocol/UAP-0.1.md.
//
// Four models + one enum. Reference engine ships post-Series-A
// (per spec §13); these tables exist now so the route stubs
// compile and the API surface is reserved.

model UAPGrant {
  id                String         @id @default(cuid())
  userId            String
  llmPartnerId      String
  scopes            String[] // ["calendar.write", "messaging.routine", ...]
  expiresAt         DateTime
  status            UAPGrantStatus @default(ACTIVE)
  consentArtifact   Json // user_response, ui_surface, shown_at
  createdAt         DateTime       @default(now())
  terminatedAt      DateTime?
  terminationReason String?

  rules      UAPRule[]
  executions UAPAuditEntry[]

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner LLMPartner @relation(fields: [llmPartnerId], references: [id])

  @@index([userId, status])
  @@index([llmPartnerId, status])
  @@index([expiresAt])
  @@map("uap_grants")
}

enum UAPGrantStatus {
  ACTIVE
  REVOKED_BY_USER
  EXPIRED
  KILLED_GLOBALLY
}

model UAPRule {
  id        String   @id @default(cuid())
  grantId   String? // null when rule is global (user-level, applies to all grants)
  userId    String // always set
  kind      String // "spending_cap" | "quiet_hours" | "irreversible_floor" | ...
  params    Json
  createdAt DateTime @default(now())

  grant UAPGrant? @relation(fields: [grantId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, grantId])
  @@map("uap_rules")
}

model UAPAuditEntry {
  id              String  @id @default(cuid())
  grantId         String
  userId          String
  llmPartnerId    String
  operation       String // "execute" | "precheck" | "grant" | "revoke" | "kill"
  actionKind      String? // when operation=execute
  decision        String // "allowed" | "denied" | "queued" | "killed"
  decisionReason  String?
  postTermination Boolean @default(false)
  signature       String // ed25519 sig of the row contents (audit-chain integrity)
  prevHash        String? // chain link to previous audit row for this user

  // v0.1.1 — outgoing-action provenance. Distinct from `signature` above
  // (which secures the audit-chain row). These columns secure the OUTGOING
  // payload that representation-action recipients verify against.
  // See docs/protocol/UAP-0.1.md §5.5.
  provenanceSignature String? // ed25519 sig of the canonical provenance payload
  provenancePublicKey String? // base64 user public key the recipient verifies against
  provenanceAlgorithm String? // "ed25519" in v0.1.1; reserved for future algs
  provenancePayload   Json? // canonical signed payload per §5.5

  createdAt DateTime @default(now())

  grant UAPGrant @relation(fields: [grantId], references: [id])

  @@index([userId, createdAt])
  @@index([grantId, createdAt])
  @@map("uap_audit_entries")
}

model UAPKillSwitchEvent {
  id               String    @id @default(cuid())
  userId           String    @unique // one active kill per user; multiple historic
  initiatedAt      DateTime  @default(now())
  propagatedAt     DateTime?
  affectedGrantIds String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("uap_kill_switch_events")
}

// ============================================================
// RAP — Risk Assessment Protocol v0.1
//
// The fifth COYL protocol. Risk classification layer that sits
// orthogonal to BIP/PAP/EAP/UAP and answers "when does an AI agent
// stop coaching and start escalating to human support?"
//
// See docs/protocol/RAP-0.1.md for the spec.
// ============================================================

/// RAP risk classes — every behavioral moment falls into exactly one.
/// See RAP-0.1.md §2 for the full definitions.
enum RAPRiskClass {
  ROUTINE_FRICTION // default — AI may coach
  PATTERN_RELAPSE // user crossed back into a left-pattern
  CRISIS_INDICATION // credible crisis signal — AI stops coaching, refers
  LEGAL_OR_MEDICAL_EMERGENCY // imminent danger — RAP supersedes everything

  @@map("rap_risk_class")
}

/// Per-moment risk assessment. NOT a per-user state — a user can be in
/// ROUTINE_FRICTION at 2:00 PM and CRISIS_INDICATION at 2:47 PM. Each
/// row is a stateless classification of one signal chain.
model RAPAssessment {
  id                 String       @id @default(cuid())
  userId             String
  riskClass          RAPRiskClass
  rationaleSignature String // sha256 of canonical signal-chain JSON
  classifierVersion  String       @default("rap-v0.1-rules-only")

  // The full inputs that drove the classification — recorded for audit
  // replay. A Trust & Safety reviewer can re-run the classifier against
  // this signal chain months later and confirm the same result.
  signalChain Json
  ttlSeconds  Int  @default(300)

  // What triggered the assessment
  triggerKind  String // "pap_proposal" | "eap_action_request" | "manual" | "bip_signal"
  triggerRefId String? // id of PAPProposal / EAPActionRequest if applicable

  // Routing decision — null when riskClass = ROUTINE_FRICTION (no
  // routing required). Populated for PATTERN_RELAPSE / CRISIS_INDICATION
  // / LEGAL_OR_MEDICAL_EMERGENCY per the envelope shapes in RAP-0.1.md §4.
  routingEnvelope Json?

  // Crisis + emergency assessments close the coaching path for the
  // session until a human-reviewed re-open is logged. Tracked here so
  // PAP can refuse new proposals while this is true.
  coachingPathClosed Boolean   @default(false)
  pathReopenedAt     DateTime?
  pathReopenedReason String?

  createdAt DateTime @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  escalations RAPEscalation[]

  @@index([userId, createdAt])
  @@index([riskClass, createdAt])
  @@index([userId, coachingPathClosed])
  @@map("rap_assessments")
}

/// Concrete escalation events — record of where RAP routed the user
/// and what happened next. One assessment can produce multiple
/// escalations (e.g., 988 + user emergency contact + clinician).
model RAPEscalation {
  id             String    @id @default(cuid())
  assessmentId   String
  escalatedTo    String // "988" | "741741" | "911" | "user_emergency_contact" | "clinician" | "pod_accountability" | other
  envelopeKind   String // "crisis_referral" | "emergency_referral" | "pattern_relapse_signal"
  outcome        String? // "user_called" | "user_dismissed" | "auto_routed" | "human_review_pending"
  outcomeNotedAt DateTime?

  createdAt DateTime @default(now())

  assessment RAPAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([escalatedTo, createdAt])
  @@map("rap_escalations")
}

// ============================================================
// INBOUND MESSAGES — replies into the check-in loop
//
// The user-defined CheckinSchedule cron pushes SMS (via Twilio) and
// email (via Resend) at the configured times. Until now the nudge was
// one-way; users got the message but couldn't talk back to the system.
//
// This table captures the return channel:
//   - SMS replies land at /api/v1/inbound/twilio (Twilio webhook,
//     signature-verified via TWILIO_AUTH_TOKEN + X-Twilio-Signature)
//   - Email replies land at /api/v1/inbound/email   (Resend inbound
//     webhook, signature-verified via Svix)
//
// Each inbound is matched back to a User (by phone via SmsSignup, or
// by from-address email match) and — when the inbound arrived within
// 12 hours of a CheckinSchedule fire — linked to `originScheduleId`.
//
// A separate cron (/api/cron/inbound-process, */5 min) flips
// processed=true after routing the row through excuse-detection so the
// inbound text becomes data the same way /api/chat messages do.
// ============================================================

model InboundMessage {
  id          String         @id @default(cuid())
  userId      String
  channel     InboundChannel
  // E.164 phone for SMS, RFC-5322 mailbox for EMAIL.
  fromAddress String
  body        String         @db.Text
  receivedAt  DateTime       @default(now())

  // Set when the inbound arrived within 12 hours of a CheckinSchedule
  // fire we sent the user. Lets the UI render "X replies" badges next
  // to the originating schedule in /settings.
  originScheduleId String?

  // Flips true after the inbound-process cron has routed the row
  // through excuse-detection / chat-pipeline downstream.
  processed Boolean @default(false)

  // Provider-specific envelope — Twilio MessageSid, Resend / SES
  // Message-ID, raw headers, etc. Json so we don't migrate every time
  // a provider adds a field we want to capture.
  metadata Json?

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  originSchedule CheckinSchedule? @relation(fields: [originScheduleId], references: [id], onDelete: SetNull)

  @@index([userId, receivedAt(sort: Desc)])
  @@index([processed])
  @@index([originScheduleId])
  @@map("inbound_messages")
}

enum InboundChannel {
  SMS
  EMAIL
}

// ============================================================
// AUTOPILOT MAP — WEEKLY WRAPPED SNAPSHOT
// ============================================================
//
// One row per user per ISO week (weekStart = Monday 00:00 UTC of the
// summarized week). Produced by /api/cron/autopilot-map-snapshot every
// Monday 06:00 UTC for the week that just ended. The marketing page at
// /autopilot-map promises a four-card "Spotify Wrapped for self-sabotage"
// artifact — this row holds the deterministic, pre-aggregated data those
// four cards render from, plus a public shareSlug for /m/[slug].
//
// The four cards (matching the existing mockup on the marketing page):
//   1. Top excuse this week        → topExcuse + topExcuseCount
//   2. Peak danger window          → peakWindowLabel + peakWindowSlips
//   3. Recovery streak             → slipsThisWeek + recoveredCount + recoveryRate
//   4. Pattern signature sentence  → patternSignature
//
// Re-running the cron upserts on (userId, weekStart) so the row is
// idempotent — useful if we need to backfill or fix an aggregation bug.
// shareSlug is generated once on first insert and preserved across
// upserts so any URL already in the wild keeps resolving.
//
// Cascade on User delete: when a user is removed, every snapshot row
// goes with them. /m/[slug] would then return 404 — which is exactly
// what we want for deleted accounts.
model AutopilotMapSnapshot {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime // Monday 00:00 UTC of the snapshot week
  weekLabel String // human-readable label, e.g. "Week of May 19"

  // Card 1 — Top excuse this week
  topExcuse      String? // ExcuseCategory enum value (e.g. "DELAY")
  topExcuseCount Int?

  // Card 2 — Peak danger window
  peakWindowLabel String? // e.g. "Wed 9-11 PM"
  peakWindowSlips Int?

  // Card 3 — Recovery streak
  slipsThisWeek  Int?
  recoveredCount Int? // slips recovered within 24h
  recoveryRate   Int? // % integer for display, 0..100

  // Card 4 — Pattern signature (a sentence)
  patternSignature String? // e.g. "9 PM Negotiator: 4 night-fridge slips, 3 recovered"

  // Sharable artifact
  shareSlug   String   @unique // public route /m/[slug] would render this
  publishedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
  @@map("autopilot_map_snapshots")
}

/**
 * ClinicalEvent — PHI-adjacent free-tier event sink for iOS + future
 * mobile surfaces. The marketing-funnel events still flow through
 * AuditFunnelEvent (the established path); ClinicalEvent is the
 * separate model for the higher-sensitivity clinical event set:
 * DANGER_WINDOW_DETECTED, INTERRUPT_FIRED, INTERRUPT_CHANGED_BEHAVIOR,
 * SLIP_REPORTED, RECOVERY_COMPLETED, KILL_SWITCH_FIRED.
 *
 * Separated because:
 *   1. BAA scope — the clinical events need to be inside the BAA-
 *      covered data boundary; the marketing funnel does not. Keeping
 *      them in distinct tables makes the audit story obvious.
 *   2. Retention policy — clinical events follow the user-owned audit
 *      log retention rules (UAP §AUDIT_QUERY); marketing funnel
 *      events follow standard product-analytics retention.
 *   3. Provider routing — marketing events also dual-write to
 *      PostHog Cloud; clinical events DO NOT leave our infra.
 *
 * `anonymousUserId` is the hash of (user.id + per-deploy salt) for
 * authenticated users, or a stable browser/device cookie hash for
 * unauthenticated users. Never the raw user id.
 *
 * `props` is a typed JSON column — the canonical type lives at
 * apps/web/src/lib/telemetry/free-tier-events.ts (FreeTierEventPayload).
 * The shape is the discriminated union there minus the base props
 * (which are columnar).
 *
 * Append-only at the application layer. There is no UPDATE or DELETE
 * call site for ClinicalEvent — modifications are forbidden by code
 * convention and (when the BAA is in place) by Postgres RLS.
 */
model ClinicalEvent {
  id                String   @id @default(cuid())

  /// Canonical event name from FreeTierEventName (clinical subset only).
  /// One of: 'interrupt.danger_window_detected' | 'interrupt.fired' |
  ///         'interrupt.changed_behavior' | 'slip.reported' |
  ///         'recovery.completed' | 'kill_switch.fired' | 'app.opened'
  name              String

  /// SHA-256 hash of (user id + per-deploy salt). Never raw.
  anonymousUserId   String

  /// Surface that emitted the event. 'ios' | 'apple-watch' |
  /// 'android' | 'wear-android' | 'web' (the last only for parity).
  surface           String

  /// App/web build version — for diffing funnels across releases.
  buildVersion      String

  /// Client-side timestamp from the device's clock. Trust with
  /// suspicion — devices can be wrong. Always compare against
  /// `serverTimestamp` when investigating ordering anomalies.
  clientTimestamp   DateTime

  /// Server-stamped timestamp — the authoritative ordering field.
  serverTimestamp   DateTime @default(now())

  /// Typed event-specific properties. See FreeTierEventPayload in
  /// apps/web/src/lib/telemetry/free-tier-events.ts for the schema.
  props             Json

  /// IP hash for rate-limiting and abuse detection. NEVER raw IP.
  ipHash            String?

  @@index([serverTimestamp(sort: Desc)])
  @@index([name])
  @@index([anonymousUserId, serverTimestamp(sort: Desc)])
  @@index([name, serverTimestamp(sort: Desc)])
  @@map("clinical_events")
}

/**
 * WaitlistEntry — the invite-only FOMO engine for the consumer launch.
 *
 * Robinhood/Lapse mechanic: join the waitlist, get a shareable invite
 * code, and jump the line (+5 effective positions) for every friend who
 * joins through your code. The "effective position" is computed at read
 * time as joinedPosition - (referralCount * SPOTS_PER_REFERRAL), floored
 * at 1 — never stored, so the boost math can be tuned without a backfill.
 *
 * Anonymous-friendly: email is the only required PII. archetypeSlug is
 * captured when the visitor came from the audit (segmentation + a warmer
 * "you're a 9 PM Negotiator — you're #4,210 in line" confirmation).
 *
 * NEDA-safe: no health/body/weight fields.
 */
model WaitlistEntry {
  id              String   @id @default(cuid())

  /// Lowercased, trimmed. The dedupe key.
  email           String   @unique

  /// Short shareable code (e.g. "COYL-7Q2F"). Unique. Drives referrals.
  inviteCode      String   @unique

  /// The inviteCode this person joined through, if any.
  referredByCode  String?

  /// Raw join order (1, 2, 3, …). Assigned at insert as count()+1.
  joinedPosition  Int

  /// How many people have joined through THIS person's inviteCode.
  referralCount   Int      @default(0)

  /// Archetype slug if they arrived from the audit. Optional.
  archetypeSlug   String?

  /// Acquisition source tag (e.g. 'audit', 'card', 'tiktok', 'direct').
  source          String?

  /// IP hash for abuse/dedupe heuristics. Never raw IP.
  ipHash          String?

  createdAt       DateTime @default(now())

  /// Wave grant — set when this entry is granted app access in a wave
  /// (admin "open the next N"). Null = still waiting. Grants are ordered
  /// by effective position so line-jumpers get in first.
  grantedAt        DateTime?

  /// When the "you're in" grant email was sent. Idempotency guard so a
  /// re-grant or retry never double-emails the same person.
  grantEmailSentAt DateTime?

  /// When they claimed their invite link (hit /redeem/[code]). Proxy for
  /// "sign-up started". Null = granted but hasn't come back yet.
  redeemedAt       DateTime?

  @@index([inviteCode])
  @@index([referredByCode])
  @@index([createdAt(sort: Desc)])
  @@index([grantedAt])
  @@map("waitlist_entries")
}

/// Passive edge signal from the phone (HealthKit v1; other sensors later).
/// One row per sample/aggregate the device syncs up. Consumed by the
/// danger-window-learner to correlate physiology with slip timing.
/// NEDA note: deliberately NO body-measurement kinds (no weight/BMI) —
/// steps, sleep, heart-rate class signals only.
model HealthSignal {
  id        String    @id @default(cuid())
  userId    String
  /// e.g. 'steps' | 'sleep_minutes' | 'heart_rate' | 'resting_heart_rate' | 'hrv'
  kind      String
  value     Float
  /// e.g. 'count' | 'min' | 'bpm' | 'ms'
  unit      String?
  startedAt DateTime
  endedAt   DateTime?
  /// e.g. 'healthkit'
  source    String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, startedAt], name: "userId_kind_startedAt")
  @@index([userId, kind, startedAt(sort: Desc)])
  @@map("health_signals")
}
