/**
 * SmsSignup — captures phone numbers from the /catch-me funnel-
 * compression landing page. These are not full users yet; they've just
 * opted into a one-shot SMS "we'll text you tonight at 9pm" intro.
 * The flow:
 * TikTok bio link → /catch-me → user enters phone → row created
 * → cron fires at user's local 9pm → introSentAt populated
 * → SMS contains a deep link back to /sign-up?ref=sms
 * Distinct from full users because (a) they haven't agreed to anything
 * beyond a single SMS, (b) we shouldn't pollute User analytics with
 * phone-only prospects, (c) GDPR right-to-erasure is cleaner on a
 * separate model.
 */
model SmsSignup {
  id              String    @id @default(cuid())
  phoneNumber     String    @unique
  source          String?
  // ISO-3166 timezone string captured at signup (browser TZ). Used by
  // the SMS-send cron to fire intro messages at the user's local 9pm.
  timezone        String?
  introSentAt     DateTime?
  // Did this signup convert to a paid or free account? Populated by the
  // sign-up flow when the SMS deep-link is followed.
  convertedAt     DateTime?
  convertedUserId String?
  createdAt       DateTime  @default(now())

  @@index([createdAt])
  @@map("sms_signups")
}

