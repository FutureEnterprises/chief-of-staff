generator client {
  provider      = "prisma-client-js"
  // Output INSIDE this package so consumers always resolve via the
  // package boundary (`@repo/database`) rather than reaching across
  // workspaces into `apps/web/.prisma/client`. The previous out-of-
  // package path produced two recurring Turbopack warnings on every
  // build:
  //   - "unexpected export *" (Prisma client is CommonJS, Turbopack
  //     can't statically tree-shake it through cross-workspace re-exports)
  //   - "Encountered unexpected file in NFT list ... apps/web/next.config.ts"
  //     (tracing the path back through the workspace boundary pulled
  //     in next.config.ts unintentionally)
  // Keeping the generated client inside the package eliminates both.
  output        = "../src/generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// USERS
// ============================================================

model User {
  id                   String            @id @default(cuid())
  clerkId              String            @unique
  email                String            @unique
  name                 String
  avatarUrl            String?
  timezone             String            @default("America/New_York")
  morningCheckinTime   String            @default("08:00")
  nightCheckinTime     String            @default("21:00")
  briefingTime         String            @default("07:00")
  reminderIntensity    ReminderIntensity @default(STANDARD)
  emailBriefingEnabled Boolean           @default(true)
  emailBriefingDays    String[]          @default(["MON", "TUE", "WED", "THU", "FRI"])
  planType             PlanType          @default(FREE)
  aiAssistsUsed        Int               @default(0)
  aiAssistsResetAt     DateTime          @default(now())
  trialEndsAt          DateTime?
  onboardingCompleted  Boolean           @default(false)
  expoPushToken        String?
  // Web Push subscription for users who don't have the mobile app yet.
  // PushSubscription JSON from the browser's PushManager.subscribe() —
  // shape: { endpoint, expirationTime, keys: { p256dh, auth } }.
  // The danger-window-interrupt cron sends web push to any user with
  // this set, in parallel with Expo push for the mobile cohort. Lets
  // web-only and pre-App-Store-launch users get real-time interrupts.
  webPushSubscription  Json?
  // Per-interrupt-channel opt-out + quiet hours. Single Json blob so
  // adding a new interrupt class (SMS, accountability partner ping,
  // etc.) doesn't require a migration. Shape:
  //   {
  //     "dangerWindow": boolean,       // default true
  //     "glp1Day3": boolean,           // default true
  //     "postSlip": boolean,           // default true
  //     "quietHoursStart": 0..23 | null, // local-tz hour, inclusive
  //     "quietHoursEnd":   0..23 | null  // local-tz hour, exclusive
  //   }
  // Crons read this before firing. Quiet hours are interpreted in the
  // user's timezone — same logic the danger-window match already uses.
  notificationPrefs    Json?
  // GLP-1 companion profile — set during onboarding for users on
  // Ozempic / Wegovy / Mounjaro / Zepbound / etc. Drives the day-3
  // post-injection intervention timing in the precision-interrupt
  // cron and unlocks the clinician-shareable summary feature for B2B
  // partners. All fields nullable so non-GLP-1 users are unaffected.
  glp1Drug             String? // Ozempic, Wegovy, Mounjaro, Zepbound, "compounded", or other free-text
  glp1InjectionWeekday Int? // 0=Sun..6=Sat — day the user injects, in their local timezone
  glp1StartedAt        DateTime? // approximate start date for the prescription
  glp1EndedAt          DateTime? // null while still on the drug; set when user comes off (triggers 90-day relapse-prevention protocol)
  // Intent data (collected during onboarding)
  role                 String?
  useCase              String?
  referralSource       String?
  biggestGoal          String?
  failurePattern       String?
  lastActiveAt         DateTime          @default(now())
  // Execution Score & Streaks
  executionScore       Int               @default(0)
  currentStreak        Int               @default(0)
  longestStreak        Int               @default(0)
  lastCompletionDate   DateTime?
  // Gamification
  level                Int               @default(1)
  xp                   Int               @default(0)
  // Public profile
  profilePublic        Boolean           @default(false)
  profileSlug          String?           @unique
  // Share-card opt-in. Gates GET /api/share/[userId] — the public OG
  // image endpoint that renders first-name + executionScore +
  // selfTrustScore + currentStreak + primaryWedge + excuseStyle.
  // Default OFF so that even if a userId leaks (DM screenshot, web
  // archive, OG preview cache), the endpoint returns 404 until the
  // user explicitly toggles share cards on in /settings.
  shareCardEnabled     Boolean           @default(false)
  // Autopilot Interruption System
  primaryWedge         PrimaryWedge      @default(PRODUCTIVITY)
  selfTrustScore       Int               @default(0)
  dangerWindows        Json? // { "mon": ["21:00-23:00"], "sat": ["14:00-18:00"] }
  excuseStyle          ExcuseCategory?
  recoveryState        RecoveryState     @default(ACTIVE)
  identityState        IdentityState     @default(SLEEPWALKING)
  toneMode             ToneMode          @default(MENTOR)
  lastSlipAt           DateTime?
  slipsThisMonth       Int               @default(0)
  // Referral / growth
  referralCode         String?           @unique
  referredByUserId     String?
  // Pending referral credit, in whole months. Each successful referral
  // grants +1 to both referrer and referred (when the referred user
  // starts paying). Credits are redeemed at next Stripe checkout as a
  // 100%-off one-cycle coupon; decremented atomically when applied.
  referralCreditMonths Int               @default(0)
  // Drive profile + personalized replacement menu. Per product-roadmap
  // v3 §"Gap 2 — Replacement Problem", generic "drink water + walk 5
  // min" doesn't satisfy the cortisol+craving loop. The user picks a
  // drive profile during onboarding (COMFORT, STIMULATION, or RELIEF)
  // and builds a 3–5-item replacement menu they actually believe in.
  // The rescue AI prompt injects this menu so suggestions land
  // personalized, not generic.
  //
  // Shape of replacementMenu:
  //   [
  //     { label: "Make a warm drink", drive: "COMFORT", est_minutes: 4 },
  //     { label: "Voice memo to Sam", drive: "STIMULATION", est_minutes: 2 },
  //     { label: "3-min mobile chess", drive: "RELIEF", est_minutes: 3 }
  //   ]
  driveProfile         DriveProfile?
  replacementMenu      Json?
  // Stripe Connect for stakes
  stripeConnectId      String?
  // Integrations
  healthIntegrations   Json? // { apple: true, google: false, calendar: "google" }
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  tasks                   Task[]
  projects                Project[]
  tags                    Tag[]
  checkins                Checkin[]
  reminders               Reminder[]
  productivityEvents      ProductivityEvent[]
  healthSignals           HealthSignal[]
  aiInteractions          AiInteraction[]
  billingSubscription     BillingSubscription?
  emailBriefings          EmailBriefing[]
  badges                  UserBadge[]
  challengeEntries        ChallengeEntry[]
  // Autopilot relations
  excuses                 Excuse[]
  dangerWindowRecords     DangerWindow[]
  rescueSessions          RescueSession[]
  decisionLogs            DecisionLog[]
  commitments             Commitment[]
  slipRecords             SlipRecord[]
  scenarios               ScenarioSim[]
  // Accountability + stakes
  partnersAsOwner         AccountabilityPartner[]    @relation("PartnerOwner")
  partnersAsPeer          AccountabilityPartner[]    @relation("PartnerPeer")
  podMemberships          PodMember[]
  challengePodMemberships ChallengePodMember[]
  podsOwned               ChallengePod[]             @relation("PodOwner")
  stakes                  Stake[]
  // Phase 1-4 moat layer relations
  signalClusters          SignalCluster[]
  predictionModels        PredictionModel[]
  dailyNumbers            DailyNumber[]
  redirectChoices         RedirectChoice[]
  // User-defined recurring check-ins. See CheckinSchedule below.
  checkinSchedules        CheckinSchedule[]
  // Referrals
  referralsMade           Referral[]                 @relation("Referrer")
  referralsReceived       Referral[]                 @relation("Referred")
  // iOS Live Activities — one row per ActivityKit Activity the user starts.
  // Server pushes interrupt updates here via APNs liveactivity-type pushes.
  // See apps/web/src/lib/live-activity-push.ts.
  liveActivities          LiveActivityRegistration[]
  // EAP + PAP coordinator relations
  devices                 Device[]
  scopeGrants             ScopeGrant[]
  papProposals            PAPProposal[]
  actionRequests          ActionRequest[]
  orchestrations          Orchestration[]
  sensorSubscriptions     SensorSubscription[]
  panicState              PanicState?
  // UAP (User-Authority Protocol) relations — standing-authority layer.
  // See docs/protocol/UAP-0.1.md.
  uapGrants               UAPGrant[]
  uapRules                UAPRule[]
  uapKillSwitchEvents     UAPKillSwitchEvent[]
  // Inbound messages (SMS replies, parsed emails) — the other side of
  // the user-defined CheckinSchedule loop. See InboundMessage below.
  inboundMessages         InboundMessage[]
  // Microsoft Graph OAuth tokens — per-user delegated access for
  // calendar + email signal pulls used by /api/cron/teams-graph-pull.
  // See TeamsUserAuth below.
  teamsUserAuth           TeamsUserAuth?
  // Autopilot Map weekly Wrapped snapshots — one row per week per user
  // (Mon 00:00 UTC weekStart). Produced by /api/cron/autopilot-map-snapshot
  // every Monday 06:00 UTC summarizing the week just ended. Powers the
  // public /m/[slug] share-card route and the in-app /autopilot-map page
  // when it switches from mockup to real data. See AutopilotMapSnapshot.
  autopilotMapSnapshots   AutopilotMapSnapshot[]

  // RAP v0.1 — risk assessment trail. Every PAP/EAP proposal that
  // touches this user is classified by RAP; the assessment row is the
  // audit record. See docs/protocol/RAP-0.1.md.
  rapAssessments RAPAssessment[]

  /// UAP v0.1.1 — per-user ed25519 signing keys for representation-
  /// action provenance signatures. Generated lazily at first UAP grant
  /// time. Private key is base64-encoded; encrypted-at-rest by the
  /// Supabase Postgres pgcrypto extension via the column policy.
  /// Rotated on KILL_SWITCH per UAP-0.1.md §6 T9.
  uapSigningKeyPublic   String?
  uapSigningKeyPrivate  String?

  @@map("users")
}

// ============================================================
// LIVE ACTIVITIES (iOS)
// ============================================================

/**
 * LiveActivityRegistration — tracks an active iOS ActivityKit Live
 * Activity so the server can push updates to it via APNs.
 * When the iOS app starts a Live Activity, ActivityKit emits two
 * push tokens via async sequences:
 * 1. The activity-scoped `pushToken` (per-activity) — used here.
 * 2. The user-scoped `pushToStartToken` — used to start NEW Live
 * Activities remotely (out of scope for this row).
 * The Expo bridge POSTs the activity-scoped token to
 * /api/v1/live-activity/register, which upserts a row here. The
 * danger-window-interrupt cron reads this table to decide whether
 * to fan an interrupt out as a Live Activity update in addition to
 * the existing Expo/Web push channels.
 * Only ONE active registration per user at a time — when a new
 * registration arrives, prior rows are flipped to active=false. This
 * mirrors the iOS spec: a user can only have one Live Activity for
 * a given attribute type running on the lock screen at once.
 */
model LiveActivityRegistration {
  id          String    @id @default(cuid())
  userId      String
  activityId  String // the iOS Activity.id returned by ActivityKit
  pushToken   String? // APNs push token for this specific activity (hex-encoded)
  interruptId String? // ProductivityEvent id this activity is associated with
  archetype   String?
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([userId, active])
  @@index([pushToken])
  @@map("live_activity_registrations")
}

// ============================================================
// AUTOPILOT INTERRUPTION SYSTEM
// ============================================================

model Excuse {
  id        String         @id @default(cuid())
  userId    String
  text      String
  category  ExcuseCategory
  source    ExcuseSource   @default(CHAT)
  context   Json?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, createdAt])
  @@map("excuses")
}

/**
 * Drive profile — the underlying need the autopilot script is trying
 * to satisfy. Maps to a personalized replacement menu (User.replacementMenu).
 * Per product-roadmap v3 §"Replacement Problem": cue → routine → reward
 * is biological; you can't remove the routine without replacing the
 * reward. Three profiles cover ~90% of cases.
 */
enum DriveProfile {
  COMFORT // warmth, soothing, safety-seeking
  STIMULATION // novelty, dopamine, distraction-seeking
  RELIEF // boredom relief, mental break, escape
}

enum ExcuseCategory {
  DELAY // "I'll start tomorrow"
  REWARD // "I deserve it"
  MINIMIZATION // "one time won't matter"
  COLLAPSE // "I already blew it"
  EXHAUSTION // "I'm too tired"
  EXCEPTION // "this week is weird"
  COMPENSATION // "I'll make up for it later"
  SOCIAL_PRESSURE // "I can't say no here"
}

enum ExcuseSource {
  CHAT
  DECISION
  RESCUE
  CHECKIN
}

model DangerWindow {
  id          String   @id @default(cuid())
  userId      String
  label       String // "Late-night kitchen", "Friday happy hour"
  dayOfWeek   Int // 0 (Sun) through 6 (Sat), -1 = all days
  startHour   Int // 0-23 local time
  endHour     Int // 0-23 local time
  triggerType String? // "stress", "social", "idle", "post-work"
  source      String   @default("user") // "user", "inferred"
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@map("danger_windows")
}

model RescueSession {
  id           String        @id @default(cuid())
  userId       String
  trigger      RescueTrigger
  customText   String?
  intervention Json // AI response
  outcome      RescueOutcome @default(PENDING)
  startedAt    DateTime      @default(now())
  resolvedAt   DateTime?
  // Public-share token for the Autopilot Interrupted card. Generated
  // when the user marks a rescue as PULLED_THROUGH and taps "share."
  // Distinct from id so the share URL can't be guessed from sequential
  // session IDs. Optional — most rescues will never be shared.
  shareCode    String?       @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([shareCode])
  @@map("rescue_sessions")
}

enum RescueTrigger {
  BINGE_URGE
  DELIVERY_URGE
  NICOTINE_URGE
  ALCOHOL_URGE
  SKIP_WORKOUT
  SKIP_WEIGHIN
  ALREADY_SLIPPED
  SPIRALING
  DOOMSCROLL
  IMPULSE_SPEND
  OTHER
}

enum RescueOutcome {
  PENDING
  INTERRUPTED // user pulled back
  SLIPPED // user did the thing anyway
  UNRESOLVED // no follow-up
}

model DecisionLog {
  id             String   @id @default(cuid())
  userId         String
  context        String // what the user was deciding
  bestMove       String?
  worstCase      String?
  excuseDetected String?
  smallestStep   String?
  userChose      String?
  outcome        String? // "followed", "slipped", "unresolved"
  savedAsTaskId  String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("decision_logs")
}

model Commitment {
  id               String              @id @default(cuid())
  userId           String
  rule             String // "no food after 9 PM"
  domain           CommitmentDomain    @default(OTHER)
  frequency        CommitmentFrequency @default(DAILY)
  active           Boolean             @default(true)
  startedAt        DateTime            @default(now())
  endsAt           DateTime?
  stakeAmountCents Int? // optional financial stake
  stakeId          String?             @unique
  keepCount        Int                 @default(0)
  breakCount       Int                 @default(0)
  lastCheckedAt    DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  stake Stake? @relation(fields: [stakeId], references: [id])

  @@index([userId, active])
  @@map("commitments")
}

enum CommitmentDomain {
  FOOD
  EXERCISE
  CRAVING
  SLEEP
  SPENDING
  FOCUS
  RELATIONSHIP
  DIGITAL
  OTHER
}

enum CommitmentFrequency {
  DAILY
  WEEKLY
  ONE_TIME
}

model SlipRecord {
  id            String    @id @default(cuid())
  userId        String
  commitmentId  String?
  trigger       String?
  notes         String?
  recoverySteps Json?
  recoveredAt   DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("slip_records")
}

model ScenarioSim {
  id          String   @id @default(cuid())
  userId      String
  scenario    String // the hypothetical
  immediate   String?
  behavioral  String?
  identityHit String?
  alternative String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("scenario_sims")
}

// ============================================================
// ACCOUNTABILITY + STAKES
// ============================================================

model AccountabilityPartner {
  id         String    @id @default(cuid())
  ownerId    String
  peerId     String?
  peerEmail  String // for pending invites
  status     String    @default("pending") // "pending", "accepted", "declined"
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  owner User  @relation("PartnerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  peer  User? @relation("PartnerPeer", fields: [peerId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([peerId])
  @@index([peerEmail])
  @@map("accountability_partners")
}

model ChallengePod {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  ownerId      String
  joinCode     String    @unique
  maxMembers   Int       @default(5)
  durationDays Int       @default(14)
  startedAt    DateTime  @default(now())
  endsAt       DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  owner   User                 @relation("PodOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members ChallengePodMember[]

  @@map("challenge_pods")
}

// Legacy challenge-pod membership (formerly `PodMember`). Renamed when
// the Phase 1-4 accountability-pod stack introduced a new, distinct
// `PodMember` model that maps to family/couples pods (see bottom of
// file). This legacy model still backs the 14/30-day challenge pods.
model ChallengePodMember {
  id       String    @id @default(cuid())
  podId    String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  role     String    @default("member") // "owner", "member"

  pod  ChallengePod @relation(fields: [podId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([podId, userId])
  @@map("challenge_pod_members")
}

model Stake {
  id             String    @id @default(cuid())
  userId         String
  amountCents    Int
  currency       String    @default("USD")
  charityLabel   String    @default("GiveDirectly")
  stripeIntentId String? // Stripe payment intent (pre-auth)
  status         String    @default("active") // "active", "released", "charged", "refunded"
  chargedAt      DateTime?
  refundedAt     DateTime?
  createdAt      DateTime  @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  commitment Commitment?

  @@index([userId])
  @@map("stakes")
}

model Referral {
  id             String    @id @default(cuid())
  referrerId     String
  referredId     String? // null until signup
  referredEmail  String?
  code           String    @unique
  converted      Boolean   @default(false)
  convertedAt    DateTime?
  referrerCredit Int       @default(0) // cents
  referredCredit Int       @default(0)
  createdAt      DateTime  @default(now())

  referrer User  @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User? @relation("Referred", fields: [referredId], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([referrerId])
  @@map("referrals")
}

// ============================================================
// ENUMS — AUTOPILOT
// ============================================================

enum PrimaryWedge {
  PRODUCTIVITY
  WEIGHT_LOSS
  CRAVINGS
  DESTRUCTIVE_BEHAVIORS
  CONSISTENCY
  SPENDING
  FOCUS
}

enum RecoveryState {
  ACTIVE // in normal flow
  SLIPPED // just slipped, needs recovery
  RECOVERING // in recovery protocol
  SILENT // inactive 3+ days
}

enum IdentityState {
  SLEEPWALKING // pre-awareness
  AVOIDANT // dodging data
  RECOVERING // post-slip
  UNSTABLE_BUT_TRYING // trying, inconsistent
  INCREASINGLY_CONSCIOUS
  RESILIENT
  DISCIPLINED
  HIGH_SELF_TRUST
}

enum ToneMode {
  MENTOR // warm, supportive
  STRATEGIST // analytical, crisp
  NO_BS // blunt, calls out avoidance
  BEAST // high-pressure, confrontational
}

model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  emoji       String
  category    String // "streak", "completion", "enforcement", "social"
  xpReward    Int      @default(10)
  requirement Json // e.g. { type: "streak", value: 7 }
  createdAt   DateTime @default(now())

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Challenge {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String
  emoji        String
  durationDays Int // 7, 14, 30
  rules        Json // { type: "daily_completions", min: 1 } or { type: "streak", min: 7 }
  xpReward     Int      @default(50)
  badgeSlug    String? // badge awarded on completion
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  entries ChallengeEntry[]

  @@map("challenges")
}

model ChallengeEntry {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  progress    Int       @default(0) // days completed
  status      String    @default("active") // "active", "completed", "failed"

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("challenge_entries")
}

enum PlanType {
  FREE
  CORE
  PLUS
  PREMIUM
  PRO // legacy — maps to CORE for existing subscribers
  TEAM // legacy — maps to PLUS for existing subscribers
}

enum ReminderIntensity {
  GENTLE
  STANDARD
  RELENTLESS
}

// ============================================================
// TASKS
// ============================================================

model Task {
  id                    String        @id @default(cuid())
  userId                String
  projectId             String?
  parentTaskId          String?
  title                 String
  description           String?
  status                TaskStatus    @default(INBOX)
  priority              TaskPriority  @default(MEDIUM)
  effortEstimate        EffortLevel?
  dueAt                 DateTime?
  nextActionAt          DateTime?
  followUpRequired      Boolean       @default(false)
  nextFollowUpAt        DateTime?
  followUpIntervalDays  Int?
  followUpMode          FollowUpMode?
  followUpStopCondition String?
  blockedReason         String?
  snoozedUntil          DateTime?
  completedAt           DateTime?
  archivedAt            DateTime?
  archiveReason         String?
  source                TaskSource    @default(MANUAL)
  aiConfidence          Float?
  aiSuggestions         Json?
  recurrenceRule        String?
  isRecurring           Boolean       @default(false)
  notes                 String?
  lastTouchedAt         DateTime?
  snoozeCount           Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parentTask         Task?               @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks           Task[]              @relation("SubTasks")
  tags               TaskTag[]
  reminders          Reminder[]
  productivityEvents ProductivityEvent[]
  aiInteractions     AiInteraction[]

  @@index([userId, status])
  @@index([userId, status, dueAt])
  @@index([userId, status, completedAt])
  @@index([userId, status, priority])
  @@index([userId, followUpRequired, nextFollowUpAt])
  @@index([userId, dueAt])
  @@index([userId, nextFollowUpAt])
  @@map("tasks")
}

enum TaskStatus {
  INBOX
  OPEN
